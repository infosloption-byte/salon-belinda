APP_NAME="Salon SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Colombo
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Database ---
# Easiest for local dev: sqlite (default). Create the file first:
#   touch database/database.sqlite
DB_CONNECTION=sqlite

# To use the shared MySQL container instead, uncomment and fill in:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=salon_saas
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync

# --- CORS: frontend + shop origins allowed to call the API ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Mail ---
# Defaults to logging emails to storage/logs/laravel.log — nothing is
# actually sent until you switch MAIL_MAILER to "smtp" and fill these in.
#
# For Gmail: turn on 2-Step Verification on the sending account, then
# create an "App Password" at https://myaccount.google.com/apppasswords
# and use that (not the normal account password) as MAIL_PASSWORD.
# Port 587 uses STARTTLS automatically — leave MAIL_SCHEME blank. Only set
# MAIL_SCHEME=smtps if you switch to port 465 instead.
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="info@yoursalon.com"
MAIL_PASSWORD=
MAIL_SCHEME=
MAIL_FROM_ADDRESS="info@yoursalon.com"
MAIL_FROM_NAME="Salon SaaS"

# Where "new appointment / new order / new message" alerts are sent.
# Defaults to MAIL_FROM_ADDRESS if left blank — set this separately if you
# want alerts going to a different inbox (e.g. the owner's personal email).
SALON_NOTIFY_EMAIL=

# Displayed on invoices/receipts/emails (single-tenant stop-gap — see
# SAAS-ROADMAP.md Phase 4 for the multi-tenant replacement).
SALON_PHONE="000 000 0000"
SALON_ADDRESS="123 Main Street, Your City"

# --- Payment gateway (not connected yet) ---
# Card payments are simulated as successful until this is filled in and
# App\Services\PaymentGatewayStub is swapped for a real integration.
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

APP_NAME="Salon Belinda"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Colombo
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Database ---
# Easiest for local dev: sqlite (default). Create the file first:
#   touch database/database.sqlite
DB_CONNECTION=sqlite

# To use the shared MySQL container instead, uncomment and fill in:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=salon_belinda
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync

# --- CORS: frontend + shop origins allowed to call the API ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Mail (defaults to logging emails to storage/logs/laravel.log) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="info.salonbelinda@gmail.com"
MAIL_FROM_NAME="Salon Belinda"

# --- Payment gateway (not connected yet) ---
# Card payments are simulated as successful until this is filled in and
# App\Services\PaymentGatewayStub is swapped for a real integration.
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

# --- Salon branding / contact info (used by src/data/site.ts) ---
# This is a stop-gap for single-tenant deployments. Once the platform is
# multi-tenant, these are replaced by a runtime fetch to the tenant config
# API and this section goes away.
VITE_SALON_NAME="Your Salon"
VITE_SALON_OWNER_NAME="Salon Owner"
VITE_SALON_OWNER_FIRST_NAME="Owner"
VITE_SALON_OWNER_TITLE="Founder & Lead Stylist"
VITE_SALON_OWNER_QUOTE="Every client should leave feeling like the most confident version of themselves."
VITE_SALON_ADDRESS="123 Main Street, Your City"
VITE_SALON_EMAIL="info@yoursalon.com"
VITE_SALON_PHONE="000 000 0000"
VITE_SALON_PHONE_HREF="tel:+10000000000"
VITE_SALON_FACEBOOK_URL="https://facebook.com"
VITE_SALON_INSTAGRAM_URL="https://instagram.com"

# URL of the standalone shop app. Opens in a new tab from the "Shop" nav link.
VITE_SHOP_URL=http://localhost:5174
# In production: VITE_SHOP_URL=https://shop.yoursalon.com

# Base URL of the Laravel API (used for services + appointment booking).
VITE_API_URL=http://localhost:8000/api
# In production: VITE_API_URL=https://api.yoursalon.com/api
